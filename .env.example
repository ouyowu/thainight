# ── App URLs (canonical, JSON-LD, Telegram links) ────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://thainight.co

# ── Supabase (optional: omit to use built-in mock data on area pages) ───────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Supabase Auth OAuth ──────────────────────────────────────────────────────
# Enable Google and Apple providers in Supabase Dashboard → Authentication → Providers.
# Dashboard callback / redirect URL:
# http://localhost:3000/auth/callback
# Production callback:
# https://your-domain.com/auth/callback

# ── Google Maps Platform (client-side map rendering + venue lookup) ──────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_API_KEY=
# Backend scripts only call live Google APIs when this is true or --force is used.
USE_LIVE_GOOGLE_DATA=false
GOOGLE_PLACES_CACHE_DAYS=30
# Set to false after the Google trial window if you want to stop rendering Google photo media URLs.
NEXT_PUBLIC_USE_GOOGLE_IMAGES=true

# ── Telegram (optional; submit-update still works without) ───────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_PUBLIC_CHANNEL_ID=

# ── Admin API: PATCH /api/submit-update ──────────────────────────────────────
ADMIN_SECRET_KEY=
CRON_SECRET=
EVENT_AUTO_IMPORT_HOSTS=phangan.events
EVENT_SOURCE_PAGES=https://phangan.events/bangkok/
EVENT_CRON_IMPORT_LIMIT=18

# ── Verification badge reference (venue detail pages) ─────────────────────────
# NEXT_PUBLIC_VERIFICATION_REFERENCE=2026-05-12T12:00:00.000Z

# ── RadarScout intelligence feed (optional) ───────────────────────────────────
# RadarScout exposes JSON at /api/thainight/intelligence.
RADARSCOUT_INTELLIGENCE_URL=https://radarscout.io/api/thainight/intelligence
# Required only if RadarScout has THAINIGHT_FEED_TOKEN set.
RADARSCOUT_FEED_TOKEN=
# Client-side city intelligence feed. Keep URL as the RadarScout origin, no trailing path.
NEXT_PUBLIC_RADARSCOUT_FEED_URL=https://radarscout.io
NEXT_PUBLIC_RADARSCOUT_API_KEY=
# Shared secret required by POST /api/radarscout/webhook.
RADARSCOUT_WEBHOOK_SECRET=

# ── Google Search Console reporting ───────────────────────────────────────────
GSC_SITE_URL=sc-domain:thainight.co
# Preferred OAuth flow: create a Google Cloud OAuth Desktop client and save it here.
GSC_OAUTH_CLIENT_PATH=secrets/gsc-oauth-client.json
GSC_OAUTH_TOKEN_PATH=secrets/gsc-oauth-token.json
# Alternative if you do not want local files:
# GSC_OAUTH_CLIENT_ID=
# GSC_OAUTH_CLIENT_SECRET=
# GSC_OAUTH_REFRESH_TOKEN=
